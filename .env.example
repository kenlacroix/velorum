# LLM Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LLM Model
LLM_MODEL=claude-sonnet-4-5-20250929

# Moltbook
MOLTBOOK_API_KEY=
MOLTBOOK_APP_KEY=
MOLTBOOK_BASE_URL=https://www.moltbook.com/api/v1

# Agent identity
AGENT_NAME=Velorum

# Agent behavior — comments
CONFIDENCE_THRESHOLD=7
MAX_RESPONSES_PER_HOUR=2
CYCLE_INTERVAL_SECONDS=300
REFLECTION_INTERVAL_CYCLES=10

# Agent behavior — original posts
MAX_POSTS_PER_DAY=3
MIN_POST_INTERVAL_SECONDS=7200
POSTING_ENABLED=true

# Conversations — reply threading
MAX_THREAD_DEPTH=3
REPLY_COOLDOWN_SECONDS=120
CONVERSATION_CHECK_INTERVAL=120
MAX_ACTIVE_CONVERSATIONS=10
STALE_CONVERSATION_HOURS=24

# Memory persistence
MEMORY_FILE=data/memory.json
